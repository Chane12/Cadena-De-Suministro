# Variables de entorno del proyecto GSCRI
# Copia este archivo como .env y rellena los valores

# ─── APIs ────────────────────────────────────────────────────────────────────
COMTRADE_API_KEY=your_un_comtrade_api_key_here
WORLD_BANK_API_KEY=                              # Opcional, la API pública no requiere key

# ─── Modelo ──────────────────────────────────────────────────────────────────
COX_PENALIZER=0.1

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                                   # DEBUG | INFO | WARNING | ERROR
